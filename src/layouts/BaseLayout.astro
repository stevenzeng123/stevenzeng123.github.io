---
import "../styles/global.css";

const { title = "My Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-zinc-950 text-zinc-100">
    <header class="border-b border-zinc-800">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
        <a href="/" class="font-semibold tracking-tight">Your Name</a>
        <div class="flex gap-4 text-sm">
          <a class="hover:text-white text-zinc-300" href="/">Home</a>
          <a class="hover:text-white text-zinc-300" href="/resume">Resume</a>
          <a class="hover:text-white text-zinc-300" href="/blog/my-first-post">Blog</a>
        </div>
      </nav>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-10">
      <slot />
    </main>

    <footer class="border-t border-zinc-800">
      <div class="mx-auto max-w-5xl px-4 py-6 text-xs text-zinc-400">
        © {new Date().getFullYear()} Your Name
      </div>
    </footer>
  </body>
</html>