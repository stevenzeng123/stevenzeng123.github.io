---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;
const { title, description, date } = frontmatter;
---

<BaseLayout title={`${title} | Your Name`}>
  <article class="mx-auto max-w-3xl">
    <a
      href="/"
      class="mb-6 inline-flex items-center text-sm text-zinc-400 transition hover:text-blue-300"
    >
      ← Back to Home
    </a>

    <header class="mb-10 border-b border-zinc-800 pb-8">
      <p class="mb-3 text-sm font-medium text-blue-400">Blog</p>

      <h1 class="text-4xl font-bold tracking-tight text-zinc-100 sm:text-5xl">
        {title}
      </h1>

      {description && (
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-zinc-300">
          {description}
        </p>
      )}

      {date && <p class="mt-4 text-sm text-zinc-400">{date}</p>}
    </header>

    <div
      class="
        prose prose-invert prose-zinc
        max-w-none
        prose-headings:tracking-tight
        prose-headings:text-zinc-100
        prose-p:text-zinc-300
        prose-p:leading-7
        prose-strong:text-zinc-100
        prose-a:text-blue-400
        prose-a:no-underline
        hover:prose-a:text-blue-300
        prose-code:text-blue-300
        prose-pre:border
        prose-pre:border-zinc-800
        prose-pre:bg-zinc-900
        prose-blockquote:border-blue-500/40
        prose-blockquote:text-zinc-300
        prose-li:text-zinc-300
      "
    >
      <slot />
    </div>
  </article>
</BaseLayout>