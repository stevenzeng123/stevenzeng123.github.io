---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Resume | Your Name">
  <h1 class="text-3xl font-bold">Resume</h1>

  <section class="mt-6 space-y-6">
    <div class="rounded-xl border border-zinc-800 p-5">
      <h2 class="text-lg font-semibold">Experience</h2>
      <ul class="mt-3 space-y-3 text-sm text-zinc-300">
        <li>
          <div class="text-zinc-100 font-medium">Role — Company</div>
          <div class="text-zinc-400">YYYY–YYYY</div>
          <div>One or two impact bullets.</div>
        </li>
      </ul>
    </div>

    <div class="rounded-xl border border-zinc-800 p-5">
      <h2 class="text-lg font-semibold">Skills</h2>
      <p class="mt-3 text-sm text-zinc-300">JavaScript, TypeScript, React, etc.</p>
    </div>
  </section>
</BaseLayout>